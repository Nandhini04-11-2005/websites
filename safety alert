<!DOCTYPE html>
<html>
<head>
<title>Women Safety Alert</title>
<style>
body
{
text-align: center;
font-family: Arial, sans-serif;
background: linear-gradient(to right, #1e1e1e, #2c3e50);
color: white;
margin-top: 100px;
}
h1 
{
  margin-bottom: 40px;
}
.btn 
{
  background-color: red;
  color: white;
  padding: 25px;
  font-size: 22px;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  width: 180px;
  height: 180px;
  transition: 0.3s;    
}
.btn:hover
{
background-color: darkred;
transform: scale(1.05);
}
#location 
{
margin-top: 30px;
font-size: 18px;
}
</style>
</head>
<body>
<h1>Women Safety Alert </h1>
<button class="btn" onclick="sendAlert()">EMERGENCY</button>
<p id="location"></p>
<script>
function sendAlert()
{
if (navigator.geolocation) 
{
navigator.geolocation.getCurrentPosition(function(position) 
{
    let lat = position.coords.latitude;
    let lon = position.coords.longitude;
    document.getElementById("location").innerHTML =" Your Location: " + lat + ", " + lon;
    alert(" Emergency Alert Sent Successfully!");
 });
} 
else
{
  alert("Geolocation not supported in this browser.");
  }
  }
</script>
</body>
</html>
